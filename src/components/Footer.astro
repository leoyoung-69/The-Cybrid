---
import NewsletterForm from './NewsletterForm.astro';

const year = new Date().getFullYear();

const socials = [
  {
    name: 'RSS',
    href: '/rss.xml',
    external: false,
    svg: '<path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1.5" fill="currentColor" stroke="none"/>',
  },
  {
    name: 'X',
    href: 'https://x.com/',
    external: true,
    svg: '<path d="M4 4l16 16M20 4L4 20" stroke-linecap="round"/>',
  },
  {
    name: 'Email',
    href: 'mailto:hello@cybrid-lab.com',
    external: false,
    svg: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/>',
  },
  // Future: Telegram
  // {
  //   name: 'Telegram',
  //   href: 'https://t.me/',
  //   external: true,
  //   svg: '<path d="M21 4L2 12l6 2 2 6 3-4 5 4 3-16z"/>',
  // },
];
---

<footer class="border-t border-(--color-border) bg-(--color-bg-primary) mt-12">
  <div class="max-w-3xl mx-auto px-4 py-10 grid gap-8 sm:grid-cols-2 text-sm text-(--color-text-secondary)">
    <div class="space-y-2">
      <p class="font-semibold text-(--color-text-primary)">Cybrid Lab</p>
      <p class="text-xs leading-relaxed">
        Cyber minds at the frontiers of finance, tech, and AI. Creating. Building. Writing what we learn.
      </p>
    </div>

    <div>
      <NewsletterForm />
    </div>
  </div>

  <div class="border-t border-(--color-border)">
    <div class="max-w-3xl mx-auto px-4 py-4 flex items-center justify-between text-xs text-(--color-text-secondary)">
      <p>&copy; {year} Cybrid Lab. All rights reserved.</p>
      <div class="flex items-center gap-4">
        {socials.map(s => (
          <a
            href={s.href}
            aria-label={s.name}
            title={s.name}
            {...(s.external ? { target: '_blank', rel: 'noopener' } : {})}
            class="hover:text-(--color-accent) transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linejoin="round"
              set:html={s.svg}
            />
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
