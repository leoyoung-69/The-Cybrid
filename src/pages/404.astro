---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | Cybrid Lab" description="This page does not exist.">
  <div class="py-16 text-center space-y-4">
    <p class="text-6xl font-bold text-(--color-text-secondary)">404</p>
    <h1 class="text-2xl font-bold">Page not found</h1>
    <p class="text-(--color-text-secondary)">
      The page you're looking for doesn't exist or has been removed.
    </p>
    <a
      href="/"
      class="inline-block text-(--color-accent) hover:text-(--color-accent-hover) transition-colors font-medium"
    >
      &larr; Back to home
    </a>
  </div>
</BaseLayout>
