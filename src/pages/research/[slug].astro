---
import PostLayout from '@layouts/PostLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('research');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const bodyWithoutFrontmatter = post.body?.replace(/^---[\s\S]*?---\s*/m, '') ?? '';
const wordCount = bodyWithoutFrontmatter.trim().split(/\s+/).filter(Boolean).length;
const readingTime = post.data.readingTime ?? Math.max(1, Math.ceil(wordCount / 200));

const tocHeadings = headings.filter(h => h.depth >= 2 && h.depth <= 3);

const allPosts = (await getCollection('research'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const currentIndex = allPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex >= 0 && currentIndex < allPosts.length - 1
  ? allPosts[currentIndex + 1]
  : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  updatedDate={post.data.updatedDate}
  category={post.data.category}
  tags={post.data.tags}
  image={post.data.image}
  imageAlt={post.data.imageAlt}
  readingTime={readingTime}
  headings={tocHeadings}
  slug={`research/${post.id}`}
  prevPost={prevPost ? { id: prevPost.id, title: prevPost.data.title } : null}
  nextPost={nextPost ? { id: nextPost.id, title: nextPost.data.title } : null}
  basePath="/research"
  backLabel="Back to research"
>
  <Content />
</PostLayout>
