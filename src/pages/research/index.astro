---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('research'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Research | Cybrid Lab"
  description="Research notes — deeper dives at the frontiers of finance, tech, and AI."
>
  <div class="space-y-8">
    <header>
      <h1 class="text-3xl font-bold">Research</h1>
      <p class="mt-2 text-(--color-text-secondary)">
        Deeper dives, work-in-progress notes, and longer-form investigations.
      </p>
    </header>

    <div class="space-y-4">
      {allPosts.map(post => (
        <PostCard
          id={post.id}
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          category={post.data.category}
          tags={post.data.tags}
          basePath="/research"
        />
      ))}
    </div>

    {allPosts.length === 0 && (
      <p class="text-(--color-text-secondary) text-center py-12">
        No research notes yet. Check back soon!
      </p>
    )}
  </div>
</BaseLayout>
