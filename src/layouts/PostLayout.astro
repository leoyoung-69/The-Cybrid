---
import BaseLayout from './BaseLayout.astro';
import TagList from '@components/TagList.astro';
import ViewCount from '@components/ViewCount.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface AdjacentPost {
  id: string;
  title: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  category: string;
  tags: string[];
  image?: string;
  imageAlt?: string;
  readingTime: number;
  headings: Heading[];
  slug: string;
  prevPost?: AdjacentPost | null;
  nextPost?: AdjacentPost | null;
  basePath?: string;
  backLabel?: string;
}

const {
  title,
  description,
  date,
  updatedDate,
  category,
  tags,
  image,
  imageAlt,
  readingTime,
  headings,
  slug,
  prevPost,
  nextPost,
  basePath = '/blog',
  backLabel = 'Back to all posts',
} = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', { dateStyle: 'long' }).format(date);
const formattedUpdated = updatedDate
  ? new Intl.DateTimeFormat('en-US', { dateStyle: 'long' }).format(updatedDate)
  : null;
---

<BaseLayout
  title={`${title} | Cybrid Lab`}
  description={description}
  image={image}
  type="article"
  publishedDate={date}
  updatedDate={updatedDate}
>
  <article class="space-y-6">
    <header class="space-y-4">
      <div class="flex flex-wrap items-center gap-3 text-sm text-(--color-text-secondary)">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span class="uppercase text-xs font-semibold tracking-wider px-2 py-0.5 rounded bg-(--color-bg-secondary)">
          {category}
        </span>
        <span>{readingTime} min read</span>
        <ViewCount slug={slug} />
      </div>
      <h1 class="text-4xl font-bold leading-tight">{title}</h1>
      <p class="text-lg text-(--color-text-secondary)">{description}</p>
      {updatedDate && (
        <p class="text-sm text-(--color-text-secondary) italic">
          Updated on {formattedUpdated}
        </p>
      )}
    </header>

    {headings.length >= 2 && (
      <nav aria-label="Table of contents" class="border border-(--color-border) rounded-lg p-4 bg-(--color-bg-secondary)/40">
        <details open>
          <summary class="cursor-pointer text-sm font-semibold text-(--color-text-primary) select-none">
            Table of Contents
          </summary>
          <ul class="mt-3 space-y-1 text-sm">
            {headings.map(h => (
              <li class={h.depth === 3 ? 'pl-4' : ''}>
                <a
                  href={`#${h.slug}`}
                  class="text-(--color-text-secondary) hover:text-(--color-accent) transition-colors"
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </details>
      </nav>
    )}

    {image && (
      <img src={image} alt={imageAlt || ''} class="w-full rounded-lg" loading="lazy" />
    )}

    <div class="prose">
      <slot />
    </div>

    <footer class="pt-6 border-t border-(--color-border) space-y-6">
      <TagList tags={tags} />

      {(prevPost || nextPost) && (
        <div class="flex gap-4 justify-between text-sm">
          <div class="flex-1 min-w-0">
            {prevPost && (
              <a
                href={`${basePath}/${prevPost.id}`}
                class="block p-3 border border-(--color-border) rounded-lg hover:border-(--color-accent) transition-colors"
              >
                <div class="text-xs text-(--color-text-secondary) mb-1">&larr; Older</div>
                <div class="line-clamp-1 font-medium">{prevPost.title}</div>
              </a>
            )}
          </div>
          <div class="flex-1 min-w-0">
            {nextPost && (
              <a
                href={`${basePath}/${nextPost.id}`}
                class="block p-3 border border-(--color-border) rounded-lg hover:border-(--color-accent) transition-colors text-right"
              >
                <div class="text-xs text-(--color-text-secondary) mb-1">Newer &rarr;</div>
                <div class="line-clamp-1 font-medium">{nextPost.title}</div>
              </a>
            )}
          </div>
        </div>
      )}
    </footer>
  </article>

  <div class="mt-8">
    <a href={basePath} class="text-(--color-accent) hover:text-(--color-accent-hover) transition-colors text-sm font-medium">
      &larr; {backLabel}
    </a>
  </div>
</BaseLayout>

<script is:inline>
  function initCodeBlocks() {
    document.querySelectorAll('.prose pre').forEach(pre => {
      if (pre.dataset.enhanced) return;
      pre.dataset.enhanced = 'true';
      const code = pre.querySelector('code');
      if (!code) return;

      const lang = code.dataset.language;
      if (lang && lang !== 'plaintext' && lang !== 'text') {
        const badge = document.createElement('span');
        badge.className = 'code-lang-badge';
        badge.textContent = lang;
        pre.appendChild(badge);
      }

      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.type = 'button';
      btn.textContent = 'Copy';
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(code.innerText);
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
        } catch (err) {
          btn.textContent = 'Failed';
          setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
        }
      });
      pre.appendChild(btn);
    });
  }
  initCodeBlocks();
  document.addEventListener('astro:after-swap', initCodeBlocks);
</script>
